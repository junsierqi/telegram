<?xml version="1.0" encoding="UTF-8"?>
<!--
  iOS .app bundle Info.plist template for app_mobile.
  Picked up by CMake via the MACOSX_BUNDLE_INFO_PLIST property when
  if(IOS) configures the app_mobile target.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
                       "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>@MACOSX_BUNDLE_BUNDLE_NAME@</string>
    <key>CFBundleDisplayName</key>
    <string>@MACOSX_BUNDLE_BUNDLE_NAME@</string>
    <key>CFBundleExecutable</key>
    <string>@MACOSX_BUNDLE_EXECUTABLE_NAME@</string>
    <key>CFBundleIdentifier</key>
    <string>@MACOSX_BUNDLE_GUI_IDENTIFIER@</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>@MACOSX_BUNDLE_SHORT_VERSION_STRING@</string>
    <key>CFBundleVersion</key>
    <string>@MACOSX_BUNDLE_BUNDLE_VERSION@</string>
    <key>CFBundleSignature</key>
    <string>????</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <!-- iOS minimum: iOS 14 covers Qt 6 baseline + ~95% of devices. -->
    <key>MinimumOSVersion</key>
    <string>14.0</string>

    <!-- iPhone (1) + iPad (2). Drop "2" if iPhone-only is desired. -->
    <key>UIDeviceFamily</key>
    <array>
        <integer>1</integer>
        <integer>2</integer>
    </array>

    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>arm64</string>
    </array>

    <key>UILaunchScreen</key>
    <dict>
        <key>UIColorName</key>
        <string>systemBackgroundColor</string>
    </dict>

    <!-- The phone-shaped UI uses the system status bar appearance. -->
    <key>UIStatusBarStyle</key>
    <string>UIStatusBarStyleDefault</string>
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <true/>

    <!-- NSAppTransportSecurity: dev TLS uses self-signed certs, so allow
         arbitrary loads for now. Production builds must remove these and
         ship ATS-compliant pinned roots instead. -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>
</dict>
</plist>
