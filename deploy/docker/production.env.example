# M115 production deployment environment template.
#
# Copy to `.env` next to docker-compose.yml and fill in the values you need:
#
#   cp deploy/docker/production.env.example deploy/docker/.env
#   $EDITOR deploy/docker/.env
#
# `docker compose --profile production --env-file deploy/docker/.env up -d`
# picks these up automatically.
#
# Anything left blank uses the safe-but-unprivileged default that ships in
# docker-compose.yml. Pending Actions (PA-*) flag the values you must
# procure before going to a real production tenant.

# ---- Postgres ----
# Override the dev password before exposing port 5432 outside the host. If
# you keep Postgres bound to the docker network only (don't publish 5432),
# the dev default is acceptable for an internal MVP.
TELEGRAM_PG_PASSWORD=telegram_dev_password
TELEGRAM_PG_PORT=5432

# ---- Server lifecycle ----
# Compose-level restart policy applied to telegram-server-prod and friends.
# `always` keeps the stack up across host reboots.
TELEGRAM_RESTART_POLICY=always
# Login session TTL in seconds (24h default; 0 disables expiry).
TELEGRAM_SESSION_TTL_SECONDS=86400

# ---- nginx-web (HTTP/WS reverse proxy) ----
# Public ports for the browser client. Default 80/443. Override if the host
# already has another web server bound to those.
TELEGRAM_HTTP_PORT=80
TELEGRAM_HTTPS_PORT=443

# ---- Prometheus (optional, --profile monitoring) ----
TELEGRAM_PROM_PORT=9090

# ---- PA-008: real push (FCM / APNs) ----
# Path *inside the container* to the FCM service-account JSON file.
# Mount the secret in via the compose `volumes:` section if you set this.
# Empty = M91's LogOnlyTransport stays the active push transport.
TELEGRAM_FCM_CREDENTIALS=

# ---- PA-009: real SMS gateway ----
# `mock` keeps M90's MockSender (writes OTPs to log). `twilio` / `aliyun`
# switch to real HTTP transports once we ship the wiring.
TELEGRAM_SMS_PROVIDER=mock
TELEGRAM_SMS_AUTH_TOKEN=

# ---- PA-011: Redis hot-state cache (M111 bridge) ----
# Empty URL = the bridge stays in FakeRedisTransport mode (in-memory).
# Set both URL and TOKEN to enable RedisHttpTransport against a real
# Upstash / ElastiCache REST gateway.
TELEGRAM_REDIS_URL=
TELEGRAM_REDIS_TOKEN=

# ---- HTTP egress proxy (only set if your host network requires one) ----
# Inherited by the build args + container env so pip install + outbound
# webhooks reach the internet through the corporate proxy.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost,postgres
